# Copy to .env.local to override (not committed). Values are baked in at `npm run build`.
#
# Dev: call Spring directly (DevTools Network shows http://localhost:8080/...):
# VITE_API_BASE_URL=http://localhost:8080
#
# Production — UI and API on same server:
# VITE_API_BASE_URL=
#
# Production — UI on CDN, API elsewhere:
# VITE_API_BASE_URL=https://your-api-host.example.com
